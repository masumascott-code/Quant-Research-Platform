# Copy to .env.production for Docker Compose production deployments.
NODE_ENV=production
PORT=8080

# Database
POSTGRES_DB=quant_research
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-postgres-password
DATABASE_URL=postgresql://postgres:replace-with-strong-postgres-password@postgres:5432/quant_research

# Redis / queue
REDIS_URL=redis://redis:6379
QUEUE_ENABLED=true
QUEUE_JOB_ATTEMPTS=3
QUEUE_JOB_BACKOFF_MS=5000
QUEUE_REMOVE_COMPLETE_AGE_SECONDS=86400
QUEUE_REMOVE_COMPLETE_COUNT=1000
WORKER_CONCURRENCY=2
WORKER_QUEUES=reports,maintenance,scanner

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_ENQUEUE_ON_START=false
SCHEDULER_IN_API_PROCESS=false
SCHEDULE_DAILY_REPORT_MS=86400000
SCHEDULE_WEEKLY_REPORT_MS=604800000
SCHEDULE_ADAPTIVE_LEARNING_MS=86400000
SCHEDULE_SCANNER_CLEANUP_MS=86400000
SCHEDULE_MARKET_SNAPSHOT_CLEANUP_MS=86400000
SCHEDULE_DATABASE_CLEANUP_MS=86400000
MARKET_SNAPSHOT_RETENTION_DAYS=30
LEARNING_HISTORY_RETENTION_DAYS=365

# API security
AUTH_ENABLED=true
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN_SECONDS=28800
JWT_ISSUER=quantedge-ai
JWT_AUDIENCE=quantedge-api
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-admin-password
VIEWER_USERNAME=viewer
VIEWER_PASSWORD=replace-with-strong-viewer-password
CORS_ORIGINS=https://your-domain.example
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10
TRUST_PROXY=true
REGISTRATION_ENABLED=false
REGISTRATION_AUTO_APPROVE=false

# Runtime
RUN_BACKGROUND_SERVICES=true
SHUTDOWN_TIMEOUT_MS=30000
LOG_LEVEL=info
SERVICE_NAME=quantedge-api

# Scanner conservative mode. Set QE_SCANNER_MODE=classic and restore thresholds
# to previous values if you need the old scanner behavior during rollout.
QE_SCANNER_MODE=conservative_v2
QE_SCANNER_MIN_SCORE_TRADE=85
QE_SCANNER_MIN_SCORE_WATCHLIST=80
QE_SCANNER_MAX_OPEN_TRADES=4
QE_SCANNER_REQUIRE_RETEST_FOR_TRADE=true
QE_SCANNER_ALLOW_BREAKOUT_WITHOUT_RETEST_TO_WATCHLIST=true

# SHORT protection diagnostics. Defaults are diagnostic-only and do not block trades.
QE_SHORT_PROTECTION_ENABLED=true
QE_SHORT_PROTECTION_DIAGNOSTIC_ONLY=true
QE_SHORT_PROTECTION_REQUIRE_BEARISH_MARKET_FOR_SHORTS=true
QE_SHORT_PROTECTION_BLOCK_SHORTS_IN_BULLISH_REGIME=true
QE_SHORT_PROTECTION_REQUIRE_SHORT_RETEST=true
QE_SHORT_PROTECTION_MAX_SHORT_EXTENSION_FROM_EMA20=0.04
QE_SHORT_PROTECTION_MAX_SHORT_EXTENSION_FROM_EMA50=0.08
QE_SHORT_PROTECTION_MAX_NEGATIVE24H_MOVE_FOR_FRESH_SHORT=-8

# Later platform modules stay disabled until explicitly enabled.
QE_SMC_SCANNER_ENABLED=true
QE_SMC_SCANNER_SHADOW_MODE=false
QE_SMC_SCANNER_PAPER_TRADING_ENABLED=true
QE_SMC_SCANNER_MIN_SMC_SCORE_TRADE=80
QE_SMC_SCANNER_MIN_SMC_SCORE_WATCHLIST=65
QE_SMC_SCANNER_MIN_RISK_REWARD=2
QE_SMC_SCANNER_MAX_OPEN_TRADES=2
QE_SMC_SCANNER_MAX_DAILY_TRADES=5
QE_SMC_SCANNER_SYMBOL_COOLDOWN_MINUTES=60
QE_SMC_SCANNER_USE_FIBONACCI_CONFLUENCE=false
QE_FUTURES_ENGINE_ENABLED=false
QE_SETUP_DNA_ENABLED=false
QE_TRADE_FORENSICS_ENABLED=false
QE_BACKTESTING_ENABLED=false
QE_RULE_BUILDER_ENABLED=false

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-grafana-password
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=replace-with-strong-grafana-password

# AI advisory layer
QE_AI_ENABLED=false
GEMINI_API_KEY=
QE_AI_MODEL_NAME=gemini-2.5-flash
QE_AI_TEMPERATURE=0.2
QE_AI_MAX_TOKENS=2048
QE_AI_TIMEOUT_MS=20000
QE_AI_RETRY_COUNT=2
QE_AI_RETRY_DELAY_MS=750
QE_AI_CACHE_TTL_MS=600000
QE_AI_RATE_LIMIT_PER_MINUTE=15

# Optional Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
