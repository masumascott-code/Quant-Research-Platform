# Copy to .env and set your PostgreSQL password.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/quant_research

# API server
PORT=8080
NODE_ENV=development

# API security
AUTH_ENABLED=true
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN_SECONDS=28800
JWT_ISSUER=quantedge-ai
JWT_AUDIENCE=quantedge-api
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin
VIEWER_USERNAME=viewer
VIEWER_PASSWORD=change-me-viewer
CORS_ORIGINS=http://localhost:21210,http://127.0.0.1:21210
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10
TRUST_PROXY=false

# Frontend (trading platform)
WEB_PORT=21210
BASE_PATH=/
API_PROXY_TARGET=http://127.0.0.1:8080

# Optional: Telegram alerts
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Optional runtime trading configuration.
# Priority: database settings > environment > defaults.
# Scanner
# QE_SCANNER_SCAN_INTERVAL_MS=30000
# QE_SCANNER_MIN_VOLUME24H=50000000
# QE_SCANNER_MIN_RVOL=1.3
# QE_SCANNER_MIN_SCORE_TRADE=90
# QE_SCANNER_MIN_SCORE_WATCHLIST=80
# QE_SCANNER_MAX_OPEN_TRADES=3
# QE_SCANNER_MAX_DAILY_TRADES=5
# QE_SCANNER_MAX_WEEKLY_TRADES=15
# QE_SCANNER_CANDLES15M_LIMIT=100
# QE_SCANNER_CANDLES5M_LIMIT=60
# QE_SCANNER_CANDLES_H1LIMIT=50
# QE_SCANNER_EXCLUDED_SYMBOL_PREFIXES=BTC,1000
# QE_SCANNER_SNAPSHOT_FRESHNESS_WINDOW_MS=300000

# Signal engine
# QE_SIGNAL_EMA_FAST_PERIOD=20
# QE_SIGNAL_EMA_SLOW_PERIOD=50
# QE_SIGNAL_EMA_TREND_PERIOD=100
# QE_SIGNAL_ATR_PERIOD=14
# QE_SIGNAL_RVOL_LOOKBACK=20
# QE_SIGNAL_BREAKOUT_LOOKBACK=10
# QE_SIGNAL_RETEST_TOLERANCE=0.003
# QE_SIGNAL_SETUP_RETEST_TOLERANCE=0.004
# QE_SIGNAL_FAKEOUT_WICK_RATIO=0.5
# QE_SIGNAL_FAKEOUT_VOLUME_RATIO=0.7
# QE_SIGNAL_MIN_RR_RATIO=2
# QE_SIGNAL_TP1RISK_MULTIPLE=1.5
# QE_SIGNAL_TP2RISK_MULTIPLE=2.5
# QE_SIGNAL_TP3RISK_MULTIPLE=4
# QE_SIGNAL_MAX_RISK_PERCENT=0.06

# Risk and paper trading
# QE_RISK_RISK_PERCENT=1
# QE_RISK_COOLDOWN_MINUTES=15
# QE_RISK_MAX_CONSECUTIVE_LOSSES=2
# QE_RISK_DAILY_DRAWDOWN_LIMIT_PERCENT=3
# QE_RISK_MAX_DRAWDOWN_PERCENT=100
# QE_RISK_MAX_EXPOSURE_PERCENT=100
# QE_RISK_MAX_PORTFOLIO_RISK_PERCENT=100
# QE_RISK_MAX_ACCOUNT_RISK_PERCENT=100
# QE_RISK_MAX_SECTOR_EXPOSURE_PERCENT=100
# QE_RISK_MAX_COIN_EXPOSURE_PERCENT=100
# QE_RISK_KILL_SWITCH=false
# QE_PAPER_TRADING_DEFAULT_EQUITY=10000
# QE_PAPER_TRADING_DEFAULT_LEVERAGE=1
# QE_PAPER_TRADING_TRADING_FEE_RATE=0
# QE_PAPER_TRADING_MAKER_FEE_RATE=0
# QE_PAPER_TRADING_TAKER_FEE_RATE=0
# QE_PAPER_TRADING_COMMISSION_RATE=0
# QE_PAPER_TRADING_SLIPPAGE_RATE=0
# QE_PAPER_TRADING_FUNDING_RATE=0
# QE_PAPER_TRADING_FUNDING_INTERVAL_HOURS=8
# QE_PAPER_TRADING_DEFAULT_QUANTITY=1

# Runtime polling
# QE_PRICE_TRACKER_POLL_INTERVAL_MS=3000
# QE_PRICE_TRACKER_SYMBOL_REFRESH_MS=30000
# QE_PRICE_TRACKER_FETCH_TIMEOUT_MS=4000
# QE_SL_MONITOR_CHECK_INTERVAL_MS=30000
