# Copy to .env and set your PostgreSQL password.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/quant_research

# API server
PORT=8080
NODE_ENV=development

# API security
AUTH_ENABLED=true
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN_SECONDS=28800
JWT_ISSUER=quantedge-ai
JWT_AUDIENCE=quantedge-api
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin
VIEWER_USERNAME=viewer
VIEWER_PASSWORD=change-me-viewer
CORS_ORIGINS=http://localhost:21210,http://127.0.0.1:21210
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10
TRUST_PROXY=false

# Frontend (trading platform)
WEB_PORT=21210
BASE_PATH=/
API_PROXY_TARGET=http://127.0.0.1:8080

# Optional: Telegram alerts
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
